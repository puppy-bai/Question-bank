.name {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat {
  min-height: 126rpx;
  text-align: center;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 800;
  color: #2563eb;
  margin-bottom: 10rpx;
}

.item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.item:last-child {
  border-bottom: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.logout {
  width: 100%;
}
