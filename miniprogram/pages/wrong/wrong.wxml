<view class="page">
  <view class="section">
    <view class="title">错题本</view>
    <view class="subtitle">完成练习后，答错的题目会自动进入这里。</view>
  </view>

  <view class="panel empty" wx:if="{{loading}}">
    <view class="empty-title">正在加载</view>
  </view>

  <view class="list" wx:elif="{{wrongQuestions.length}}">
    <view class="panel wrong-item" wx:for="{{wrongQuestions}}" wx:key="id">
      <view bindtap="openWrong" data-bank-id="{{item.bankId}}" data-question-id="{{item.questionId}}">
        <view class="wrong-stem">{{item.stem}}</view>
        <view class="muted">{{item.type}} · 错误 {{item.wrongCount}} 次</view>
      </view>
      <view class="actions">
        <button class="mini-btn" bindtap="openWrong" data-bank-id="{{item.bankId}}" data-question-id="{{item.questionId}}">去复习</button>
        <button class="mini-btn secondary" bindtap="markMastered" data-id="{{item.id}}">已掌握</button>
      </view>
    </view>
  </view>

  <view class="panel empty" wx:else>
    <view class="empty-title">暂无错题</view>
    <view class="muted">完成练习后，答错的题目会出现在这里。</view>
  </view>
</view>
