.empty {
  text-align: center;
  padding: 56rpx 28rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.wrong-item {
  line-height: 1.6;
}

.wrong-stem {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.mini-btn {
  height: 64rpx;
  padding: 0;
  border-radius: 10rpx;
  background: #eaf2ff;
  color: #1d4ed8;
  font-size: 24rpx;
  line-height: 64rpx;
}

.mini-btn.secondary {
  background: #f1f5f9;
  color: #334155;
}
