.picker {
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  box-sizing: border-box;
  background: #ffffff;
  line-height: 88rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.field {
  margin-top: 18rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #334155;
  font-weight: 700;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  box-sizing: border-box;
  background: #ffffff;
}

.tip {
  margin-top: 16rpx;
  line-height: 1.6;
}

.save {
  width: 100%;
  margin-top: 24rpx;
}

.chapter-field {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 180rpx;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.chapter-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.chapter-input {
  text-align: right;
}
