<view class="page">
  <view class="section">
    <view class="title">收藏夹</view>
    <view class="subtitle">收藏的题目会出现在这里，可直接跳回题库复习。</view>
  </view>

  <view class="panel empty" wx:if="{{loading}}">
    <view class="empty-title">正在加载</view>
  </view>

  <view class="list" wx:elif="{{favorites.length}}">
    <view class="panel favorite-item" wx:for="{{favorites}}" wx:key="id">
      <view bindtap="openFavorite" data-bank-id="{{item.bankId}}" data-question-id="{{item.questionId}}">
        <view class="favorite-stem">{{item.stem}}</view>
        <view class="muted">{{item.bankName || '题库'}} · {{item.chapterName || '默认章节'}} · {{item.type}}</view>
      </view>
      <button class="mini-btn" data-question-id="{{item.questionId}}" bindtap="removeFavorite">取消收藏</button>
    </view>
  </view>

  <view class="panel empty" wx:else>
    <view class="empty-title">暂无收藏</view>
    <view class="muted">在答题页点击“收藏”，题目就会保存到这里。</view>
  </view>
</view>
