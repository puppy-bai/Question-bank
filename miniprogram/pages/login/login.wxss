.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand {
  margin-bottom: 56rpx;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry-card {
  padding: 34rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
}

.form-card {
  display: block;
}

.user-entry {
  border-color: #bfdbfe;
}

.admin-entry {
  border-color: #c7d2fe;
}

.entry-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.entry-desc {
  color: #64748b;
  line-height: 1.55;
  margin-bottom: 22rpx;
}

.entry-action {
  min-width: 96rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  line-height: 60rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.entry-action.secondary {
  background: #4f46e5;
}

.center {
  text-align: center;
}

.input {
  width: 100%;
  height: 88rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  background: #ffffff;
  box-sizing: border-box;
}

.login-button {
  width: 100%;
  margin-top: 24rpx;
}
