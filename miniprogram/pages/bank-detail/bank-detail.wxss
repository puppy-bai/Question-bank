.hero {
  padding-bottom: 34rpx;
}

.bank-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.desc {
  line-height: 1.55;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 30rpx;
}

.metric-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #2563eb;
  margin-bottom: 8rpx;
}

.join-button {
  width: 100%;
  margin-top: 24rpx;
}

.joined-tip {
  margin-top: 24rpx;
  color: #047857;
  font-weight: 700;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
}

.action-grid .button {
  width: 100%;
  padding: 0;
  font-size: 26rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.section-head {
  margin-bottom: 20rpx;
}

.chapter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.chapter-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.chapter-action {
  min-width: 86rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #1d4ed8;
  line-height: 52rpx;
  text-align: center;
  font-weight: 700;
}

.empty {
  padding-top: 20rpx;
}
