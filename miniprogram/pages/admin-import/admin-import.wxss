.hint {
  margin-top: 18rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.preview-question {
  padding: 22rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.preview-stem {
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.bank-input {
  height: 88rpx;
  margin-top: 24rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
  box-sizing: border-box;
  background: #ffffff;
}

.confirm {
  margin: 20rpx 0 10rpx;
}

.debug {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.warn-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #9a3412;
  line-height: 1.6;
}

.warn-title {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.raw-line {
  margin-top: 8rpx;
  color: #7c2d12;
  font-size: 24rpx;
  word-break: break-all;
}
