page {
  min-height: 100%;
  background: #f6f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 28rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  margin-top: 12rpx;
  color: #64748b;
  line-height: 1.6;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.button {
  height: 80rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 80rpx;
  padding: 0 28rpx;
}

.button.secondary {
  background: #eaf2ff;
  color: #1d4ed8;
}

.muted {
  color: #64748b;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 22rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
